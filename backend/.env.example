# Supabase Configuration for Backend (legacy — optional if using self-hosted Postgres only)
# Copy this file to .env and fill in your actual values

# Supabase Service Role Key (for backend operations)
# Get this from your Supabase project dashboard: Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your_actual_service_role_key_here

# Note: The Supabase URL is hardcoded in database.py to match the frontend
# SUPABASE_URL=https://yhticndmpvzczquivpfb.supabase.co

# --- Self-hosted PostgreSQL (required for /auth/*) ---
# Format: postgresql://USER:PASSWORD@HOST:5432/DATABASE
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_EC2_HOST:5432/rethinkcarbon

# --- JWT auth (required for /auth/*) ---
# Use a long random string (e.g. openssl rand -hex 32)
JWT_SECRET=change-me-to-a-long-random-secret

# Optional
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# CORS (optional, comma-separated)
# ALLOWED_ORIGINS=http://localhost:8080,https://www.rethinkcarbon.io
